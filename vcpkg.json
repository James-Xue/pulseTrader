{
  "name": "pulsetrader",
  "version": "0.1.0",
  "description": "AI-driven scalping framework with adaptive strategy tuning via real-time social signals",
  "dependencies": [
    "nlohmann-json",
    "spdlog",
    "fmt",
    "curl",
    "openssl",
    "asio",
    "gtest",
    "toml11"
  ],
  "features": {
    "sqlite": {
      "description": "SQLite persistence for TradeRecorder (enable with -DPULSE_ENABLE_SQLITE=ON)",
      "dependencies": ["sqlitecpp"]
    },
    "webui": {
      "description": "WebUI dashboard server (enable with -DPULSE_ENABLE_WEBUI=ON)",
      "dependencies": ["uwebsockets"]
    }
  }
}
